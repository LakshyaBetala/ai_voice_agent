# Supabase (local + cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare (only needed for deploy)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Sarvam / Exotel / Resend — wired in Plan 2 & 3
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SAMVAAD_BASE_URL=https://api.sarvam.ai/v1/samvaad
SAMVAAD_WEBHOOK_SECRET=

EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_CALLER_ID=

RESEND_API_KEY=

# Internal worker auth (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
INTERNAL_API_TOKEN=

# Worker URLs (filled after `wrangler deploy`)
CAMPAIGNS_WORKER_URL=
WEBHOOKS_WORKER_URL=
SCORE_WORKER_URL=
HANDOFF_WORKER_URL=
CLICKTOCALL_WORKER_URL=
